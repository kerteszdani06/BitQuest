<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootDungeon"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvFloor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Floor 1"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvMissionDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mission description"
            android:textSize="16sp"
            android:layout_marginBottom="16dp" />

        <ImageView
            android:id="@+id/imgMonster"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/monster"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvMonsterName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Monster"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/progressMonster"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="100"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvLeadHero"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lead Hero"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/imgLead"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginBottom="12dp" />

        <ProgressBar
            android:id="@+id/progressLead"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="100"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvPartnerHero"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Partner Hero"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <ImageView
            android:id="@+id/imgReserve1"
            android:layout_width="72dp"
            android:layout_height="72dp" />

        <ImageView
            android:id="@+id/imgReserve2"
            android:layout_width="72dp"
            android:layout_height="72dp" />

        <Button
            android:id="@+id/btnAttack"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Attack"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnDefend"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Defend"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnSpecial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Use Special Ability"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnSwap1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/swap_with_reserve_1" />

        <Button
            android:id="@+id/btnSwap2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/swap_with_reserve_2" />

        <TextView
            android:id="@+id/tvPotionCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/potions_0"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnUsePotion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/use_potion"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/combat_log"
            android:textStyle="bold"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tvCombatLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/battle_begins"
            android:padding="12dp"
            android:background="#DDDDDD"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>