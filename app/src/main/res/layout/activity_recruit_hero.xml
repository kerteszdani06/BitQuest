<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Recruit Hero"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/etHeroName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter hero name"
            android:layout_marginBottom="16dp" />

        <RadioGroup
            android:id="@+id/radioGroupClasses"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <RadioButton
                android:id="@+id/rbKnight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Knight" />

            <RadioButton
                android:id="@+id/rbArcher"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Archer" />

            <RadioButton
                android:id="@+id/rbCleric"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cleric" />

            <RadioButton
                android:id="@+id/rbWizard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Wizard" />

            <RadioButton
                android:id="@+id/rbNecromancer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Necromancer" />
        </RadioGroup>

        <Button
            android:id="@+id/btnConfirmRecruit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Confirm" />

    </LinearLayout>
</ScrollView>